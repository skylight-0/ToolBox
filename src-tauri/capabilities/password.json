{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "password-capability",
  "description": "Capability for the standalone password manager window",
  "windows": ["password"],
  "permissions": [
    "core:default",
    "core:window:allow-close",
    "core:window:allow-set-focus",
    "clipboard-manager:allow-write-text"
  ]
}
